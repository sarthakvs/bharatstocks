# Copy this file to ".env" and fill in your values.
#   cp .env.example .env
# ".env" is git-ignored — it never gets committed. The app auto-loads it on
# startup (via python-dotenv). On a cloud host, set these in the platform's
# secret store / dashboard instead of shipping a .env file.

# ---- App login (set on ANY non-local deployment so the app isn't public) ----
APP_PASSWORD=
APP_USERNAME=admin

# ---- Email price alerts (Gmail: create an App Password — NOT your real password) ----
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
ALERT_FROM=
ALERT_TO=

# ---- Server ----
# PORT=5000
# WEB_CONCURRENCY=1
# THREADS=8
# ALERTS_INTERVAL=300

# ---- Broker API keys are intentionally NOT stored here ----
# Kotak/ICICI keys can PLACE TRADES, so they're entered in the UI per-use and
# never persisted. Keep broker import on your local machine only.
